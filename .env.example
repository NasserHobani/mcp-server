CS_AI_BRIDGE_BASE_URL=http://localhost:8069
CS_AI_BRIDGE_TIMEOUT=30

# Redis schema metadata settings
CS_AI_BRIDGE_REDIS_URL=redis://localhost:6379/0
CS_AI_BRIDGE_SCHEMA_KEY_PREFIX=cs_ai_bridge:schema
# TTL (seconds); 0 = no in-process cache unless pub/sub invalidated entry is repopulated via read
CS_AI_BRIDGE_SCHEMA_CACHE_TTL_SECONDS=0
# Matches Odoo "Schema" pub/sub channel — set CS_AI_BRIDGE_SCHEMA_PUBSUB=1 to auto-invalidate cache
CS_AI_BRIDGE_REDIS_SCHEMA_CHANNEL=odoo.mcp.schema
CS_AI_BRIDGE_SCHEMA_PUBSUB=0

# Default tenant/db name hints for schema lookups when MCP tool omits tenant
CS_AI_BRIDGE_TENANT=

# Optional: Odoo credential auth (used when CS_AI_BRIDGE_COOKIE is empty).
CS_AI_BRIDGE_ODOO_EMAIL=
CS_AI_BRIDGE_ODOO_DB_NAME=
CS_AI_BRIDGE_ODOO_PASSWORD=

# Optional: pass an Odoo session cookie for auth="user" routes.
# Example: session_id=<your_odoo_session_cookie>
CS_AI_BRIDGE_COOKIE=

# Optional: extra HTTP headers as JSON.
# Example: {"X-Tenant":"db_a","X-Forwarded-User":"admin"}
CS_AI_BRIDGE_HEADERS_JSON={}

# ai_query — refresh schema from Redis before calling Odoo; validate hints locally
CS_AI_BRIDGE_AI_VALIDATE_SCHEMA=true
# When true along with SCHEMA_CACHE_TTL_SECONDS>0, reuse cached schema between calls (default tool param is false)
CS_AI_BRIDGE_AI_REUSE_SCHEMA_CACHE=false
