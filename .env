CS_AI_BRIDGE_BASE_URL=http://jhzly:8069
CS_AI_BRIDGE_TIMEOUT=30

# Optional: Odoo credential auth (used when CS_AI_BRIDGE_COOKIE is empty).
CS_AI_BRIDGE_ODOO_EMAIL=admin
CS_AI_BRIDGE_ODOO_DB_NAME=jhzly
CS_AI_BRIDGE_ODOO_PASSWORD=admin

# Optional: pass an Odoo session cookie for auth="user" routes.
# Example: session_id=<your_odoo_session_cookie>
CS_AI_BRIDGE_COOKIE=

# Optional: extra HTTP headers as JSON.
# Example: {"X-Tenant":"db_a","X-Forwarded-User":"admin"}
CS_AI_BRIDGE_HEADERS_JSON={}
